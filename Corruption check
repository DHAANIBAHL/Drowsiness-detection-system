import os
import random
from PIL import Image

BASE = r'C:\Users\HP\.cache\kagglehub\datasets\talhabhatti7262\drivers-drowsiness-detection\versions\1\Final\PreparedData'

TRAIN_OPEN   = os.path.join(BASE, 'train', 'openEye')
TRAIN_CLOSED = os.path.join(BASE, 'train', 'closeEye')
TEST_OPEN    = os.path.join(BASE, 'test',  'openEye')
TEST_CLOSED  = os.path.join(BASE, 'test',  'closeEye')

def check_corrupted_sample(folder, label, sample_size=500):
    all_files = [f for f in os.listdir(folder) if f.endswith('.png')]
    
    # sample randomly instead of checking all
    sampled = random.sample(all_files, min(sample_size, len(all_files)))
    
    bad = []
    for f in sampled:
        try:
            img = Image.open(os.path.join(folder, f))
            img.verify()
        except:
            bad.append(f)
    
    status = "Clean" if not bad else f"{len(bad)} bad files found"
    print(f"  {label:20s} → sampled {len(sampled):,} files → {status}")

check_corrupted_sample(TRAIN_OPEN,   'Train Open')
check_corrupted_sample(TRAIN_CLOSED, 'Train Closed')
check_corrupted_sample(TEST_OPEN,    'Test Open')
check_corrupted_sample(TEST_CLOSED,  'Test Closed')
print("\nCorruption check is completed.")
