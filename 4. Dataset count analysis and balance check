# Dataset count and balance check
train_open   = len([f for f in os.listdir(TRAIN_OPEN)   if f.endswith('.png')])
train_closed = len([f for f in os.listdir(TRAIN_CLOSED) if f.endswith('.png')])
test_open    = len([f for f in os.listdir(TEST_OPEN)    if f.endswith('.png')])
test_closed  = len([f for f in os.listdir(TEST_CLOSED)  if f.endswith('.png')])

total_train = train_open + train_closed
total_test  = test_open  + test_closed
total       = total_train + total_test

print("=" * 50)
print("          DATASET REPORT")
