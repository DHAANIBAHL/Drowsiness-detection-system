print(f"  TRAIN open   : {train_open:>7,}  ({train_open/total_train*100:.1f}%)")
print(f"  TRAIN closed : {train_closed:>7,}  ({train_closed/total_train*100:.1f}%)")
print(f"  TRAIN total  : {total_train:>7,}")
print("-" * 50)
print(f"  TEST  open   : {test_open:>7,}  ({test_open/total_test*100:.1f}%)")
print(f"  TEST  closed : {test_closed:>7,}  ({test_closed/total_test*100:.1f}%)")
print(f"  TEST  total  : {total_test:>7,}")
print("-" * 50)
print(f"  GRAND TOTAL  : {total:>7,}")
print("=" * 50)
